    {
      "parameters": {
        "jsCode": "// Données du mail en cours (depuis le Gmail Trigger)\nconst currentMail = $('Gmail Trigger').item.json;\nconst currentBody = currentMail.text || '';\nconst currentSubject = currentMail.subject || '';\n\n// Lignes du Google Sheet (depuis Get Rows)\nconst rows = $input.all();\n\n// Filtre : 7 derniers jours, score >= 7, exclure doublons déjà détectés\nconst sevenDaysAgo = Date.now() - (7 * 24 * 60 * 60 * 1000);\n\nconst recentJDs = rows\n  .map(r => r.json)\n  .filter(r => {\n    const rowDate = new Date(r['Date']).getTime();\n    const score = parseInt(r['Score']) || 0;\n    const statut = r['Statut'] || '';\n    return rowDate >= sevenDaysAgo && score >= 7 && statut !== 'doublon-maybe';\n  })\n  .map(r => ({\n    id: r['Mail-ID'],\n    sujet: r['Sujet'],\n    raison: r['Raison']\n  }));\n\nreturn [{\n  json: {\n    currentSubject,\n    currentBody,\n    currentMailId: currentMail.id,\n    recentJDs\n  }\n}];"
      },
