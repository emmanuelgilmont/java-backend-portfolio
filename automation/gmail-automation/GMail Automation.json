    {
      "parameters": {
        "jsCode": "const now = new Date();\n\nconst h = parseInt(new Intl.DateTimeFormat('fr-BE', { \n  hour: 'numeric', hour12: false, \n  timeZone: 'Europe/Brussels' \n}).format(now));\n\nconst m = parseInt(new Intl.DateTimeFormat('fr-BE', { \n  minute: 'numeric', \n  timeZone: 'Europe/Brussels' \n}).format(now));\n\nconst plage1 = (h === 6 && m >= 5 && m <= 20);\nconst plage2 = (h === 18 && m >= 5 && m <= 20);\n\nif (!plage1 && !plage2) {\n  throw new Error(`Hors plage — ${h}h${m} — exécution annulée.`);\n}\n\nreturn $input.all();"
      },
