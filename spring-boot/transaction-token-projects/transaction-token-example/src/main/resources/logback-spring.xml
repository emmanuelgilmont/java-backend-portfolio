<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
        The key piece: %X{transactionToken} reads the MDC value set by TokenFilter.
        Every log line is automatically prefixed with the transaction token.
        No code change needed in controllers or services.
    -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%X{transactionToken}] %-5level %-40logger{40} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/application.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <!-- Same pattern in the file — grep on a token gives you the full transaction -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{transactionToken}] %-5level %-40logger{40} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Application logs at DEBUG to show full trace in the example -->
    <logger name="be.gate25.example" level="DEBUG"/>

    <!-- Starter internals at INFO -->
    <logger name="be.gate25.tokencontext" level="INFO"/>

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>