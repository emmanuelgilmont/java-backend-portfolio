<?xml version="1.0" encoding="UTF-8"?>
<!--
  Place this file at src/main/resources/logback-spring.xml
  (replace any existing logback-spring.xml, or merge if a "test" profile is already defined there).

  Two profiles:
    - "local"  : human-readable console output (dev on the Windows machine, IntelliJ)
    - default  : structured JSON (homelab / container), one JSON object per line, ready to be
                 ingested by any log collector later on (Loki, Promtail... out of scope for
                 this task, but the format is already compatible).

  The "transactionToken" field comes from the MDC set by be.gate25.tokencontext.TokenFilter
  (transaction-token-starter) and appears automatically in EVERY JSON log line, without any
  change needed in business code (RateService, RateController, ...).
-->
<configuration>

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProfile name="local">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%X{transactionToken}] %-5level %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="!local">
        <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <!-- Standard fields always present: timestamp, level, logger, message,
                     thread, plus the full MDC content (including transactionToken) -->
                <customFields>{"service":"fx-rate-service"}</customFields>
                <fieldNames>
                    <timestamp>timestamp</timestamp>
                    <message>message</message>
                    <logger>logger</logger>
                    <thread>thread</thread>
                    <level>level</level>
                </fieldNames>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
    </springProfile>

</configuration>
